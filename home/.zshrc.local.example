#!/bin/bash

# =============================================================================
# MACHINE-LOCAL ZSH CONFIG (non-secret)
# =============================================================================
#
# Copy this file to ~/.zshrc.local and set per-machine values.
# Sourced by ~/.zshrc AFTER ~/.secrets, BEFORE the rest of the config.
#
# Only put NON-SENSITIVE machine-specific values here (paths, IPs, hostnames).
# Put real secrets (API keys, tokens, passwords) in ~/.secrets instead.
#
# =============================================================================

# Sandbox VM IP (UTM Fedora Server).
# Must match the HostName in your ~/.ssh/config "Host sandbox" entry.
# Used by sbup() to poll for SSH readiness after VM start.
export SANDBOX_IP="192.168.64.10"
