# SSH client configuration
# This file manages SSH connections to various servers and services
#
# Identity management options:
#   1. Bitwarden SSH Agent (recommended): Set IdentityAgent to ~/.bitwarden-ssh-agent.sock
#   2. SSH key files: Set IdentityFile to your key path
#
# Bitwarden SSH Agent setup (macOS):
#   Add to .zshrc:
#     export SSH_AUTH_SOCK="$HOME/.bitwarden-ssh-agent.sock"
#     launchctl setenv SSH_AUTH_SOCK "$SSH_AUTH_SOCK"

# GitHub - Git operations
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

# GitLab - Alternative Git hosting
Host gitlab.com
    HostName gitlab.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

# Bitbucket - Git hosting
Host bitbucket.org
    HostName bitbucket.org
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

# Local VM / Sandbox
Host sandbox
    HostName YOUR_SANDBOX_IP
    User YOUR_USERNAME
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

# Pantheon (Drupal/WordPress hosting)
Host *.drush.in
    Port 2222
    IdentityFile ~/.ssh/pantheon_2048
    IdentitiesOnly yes
    PubkeyAcceptedAlgorithms +ssh-rsa
    HostKeyAlgorithms +ssh-rsa

# WP Engine
Host *.wpengine.net
    IdentityFile ~/.ssh/YOUR_WPE_KEY
    IdentitiesOnly yes

